#include <stdio.h>

int findSmallestCommonDivisor(int a, int b) {
    int min = (a < b) ? a : b;
    for(int i = 2; i <= min; i++) {
        if(a % i == 0 && b % i == 0)
            return i;
    }
    return -1; // No common divisor other than 1
}

int findGCD(int a, int b) {
    while(b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main() {
    int num1, num2, gcd, scd;

    printf("Enter two numbers:\n");
    scanf("%d %d", &num1, &num2);

    scd = findSmallestCommonDivisor(num1, num2);
    gcd = findGCD(num1, num2);

    if(scd != -1)
        printf("Smallest Common Divisor: %d\n", scd);
    else
        printf("No common divisor other than 1.\n");

    printf("Greatest Common Divisor (GCD): %d\n", gcd);

    return 0;
}
