void inverse2x2(int m[2][2]) {
    int a = m[0][0], b = m[0][1], c = m[1][0], d = m[1][1];
    int det = a*d - b*c;
    if(det == 0) {
        printf("Inverse does not exist (det = 0).\n");
        return;
    }
    printf("Inverse:\n");
    printf("%.2f\t%.2f\n", d/(float)det, -b/(float)det);
    printf("%.2f\t%.2f\n", -c/(float)det, a/(float)det);
}

int isMagicSquare(int m[SIZE][SIZE], int n) {
    int sum = 0;
    for(int j=0; j<n; j++) sum += m[0][j];

    for(int i=1; i<n; i++) {
        int rowSum = 0;
        for(int j=0; j<n; j++) rowSum += m[i][j];
        if(rowSum != sum) return 0;
    }

    for(int j=0; j<n; j++) {
        int colSum = 0;
        for(int i=0; i<n; i++) colSum += m[i][j];
        if(colSum != sum) return 0;
    }

    int diag1 = 0, diag2 = 0;
    for(int i=0; i<n; i++) {
        diag1 += m[i][i];
        diag2 += m[i][n-i-1];
    }
    return (diag1 == sum && diag2 == sum);
}

