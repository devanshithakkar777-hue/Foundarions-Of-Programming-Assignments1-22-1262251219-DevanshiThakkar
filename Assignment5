}

//Saddle Point in a Matrix
#include <stdio.h>

int main() {
    int m, n;
    printf("Enter number of rows and columns: ");
    scanf("%d %d", &m, &n);

    int mat[m][n];
    printf("Enter elements of the matrix:\n");
    for(int i = 0; i < m; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    int found = 0;
    for(int i = 0; i < m; i++) {
        int minRow = mat[i][0];
        int colIndex = 0;

        // Find minimum in row
        for(int j = 1; j < n; j++) {
            if(mat[i][j] < minRow) {
                minRow = mat[i][j];
                colIndex = j;
            }
        }

        // Check if minRow is maximum in its column
        int isSaddle = 1;
        for(int k = 0; k < m; k++) {
            if(mat[k][colIndex] > minRow) {
                isSaddle = 0;
                break;
            }
        }

        if(isSaddle) {
            printf("Saddle point found at (%d,%d): %d\n", i+1, colIndex+1, minRow);
            found = 1;
        }
    }

    if(!found)
        printf("No saddle point exists in the matrix.\n");

    return 0;
}

