#include <stdio.h>
#include <math.h>

int factorial(int num) {
    int fact = 1;
    for(int i = 1; i <= num; i++)
        fact *= i;
    return fact;
}

int main() {
    int n;
    float x, sum = 0;
    printf("Enter value of x (in radians): ");
    scanf("%f", &x);
    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        int power = 2 * i + 1;
        float term = pow(x, power) / factorial(power);
        if(i % 2 == 0)
            sum += term;
        else
            sum -= term;
    }

    printf("Sum of sine series = %.6f\n", sum);
    return 0;
}
